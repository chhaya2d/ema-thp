# Copy to `.env` in the **project root** (same directory as `settings.gradle.kts`).
# `Main` and `DemoWebServer` call `RuntimeEnv.loadDotEnv()` at startup and merge these with
# OS environment variables (**OS env wins** when set and non-blank).
#
# Run web from project root: `.\gradlew.bat run --args web` so `.env` resolves.

# -----------------------------------------------------------------------------
# Production-style flow: real Google OAuth + Postgres for tokens (DEFAULT)
# -----------------------------------------------------------------------------
# Do **not** set EMA_WEB_USE_MOCK_CONNECTORS, or set it to false.

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional — defaults to http://localhost:8080/oauth/google/callback (match WEB_PORT).
# Must match Google Cloud "Authorized redirect URIs" exactly (localhost ≠ 127.0.0.1).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/oauth/google/callback

CONNECTOR_TOKEN_KEY=change-me-in-dev-only

WEB_PORT=8080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=emathp
POSTGRES_USER=emathp
POSTGRES_PASSWORD=emathp
# Or single URL:
# EMA_JDBC_URL=jdbc:postgresql://localhost:5432/emathp

DEMO_USER_ID=demo-user

# Optional: in-memory H2 instead of Postgres when testing real connector without Docker
# EMA_DEV_H2=true

# -----------------------------------------------------------------------------
# Quick demo only: mock Google + mock Notion — no DB, no OAuth
# -----------------------------------------------------------------------------
# EMA_WEB_USE_MOCK_CONNECTORS=true
